pipeline {
    agent any

    tools {
        maven 'Maven'   // Make sure Maven is configured in Jenkins
    }

    environment {
        JMETER_HOME = 'C:\\apache-jmeter-5.6.3'   // Update if needed
        PATH = "${env.PATH};${JMETER_HOME}\\bin"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/HarshAkhand05/PrimaryTrack_FinalProject.git'
            }
        }

        stage('Build Project') {
            steps {
                bat 'mvn clean verify "-Dmaven.test.failure.ignore=true"'
            }
        }

        stage('Start Selenium Grid') {
            steps {
                echo 'Starting Selenium Grid...'
                bat 'start /B java -jar selenium-server-4.41.0.jar standalone'
                timeout(time: 20, unit: 'SECONDS') {
                    sleep 20
                }
            }
        }

        stage('Run Selenium Tests') {
            steps {
                echo 'Running Selenium Tests...'
                bat 'mvn test'
            }
        }

        stage('Run JMeter Tests') {
            steps {
                echo 'Running JMeter Tests...'
                bat 'jmeter -n -t testplan.jmx -l result.jtl'
            }
        }

        stage('Archive Results') {
            steps {
                archiveArtifacts artifacts: '**/target/*.jar, **/*.jtl', allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            echo 'Build Finished!'
        }
        success {
            echo 'SUCCESS ✅'
        }
        failure {
            echo 'FAILED ❌'
        }
    }
}
